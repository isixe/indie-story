---
import { t, getLangFromPath, type Lang } from '../i18n';

interface Props {
  lang?: Lang;
}

const currentYear = new Date().getFullYear();
const lang = Astro.props.lang || getLangFromPath(Astro.url.pathname);
---

<footer style="margin-top: var(--space-3xl); padding-top: var(--space-xl);">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between" style="gap: var(--space-md);">
    <p class="font-sans text-xs text-[var(--color-text-muted)]">
      Indie Story
    </p>
    <p class="font-sans text-xs text-[var(--color-text-light)]">
      {t(lang, 'footer')} · {currentYear}
    </p>
  </div>
</footer>