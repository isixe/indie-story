---
import { t, getLangFromPath, type Lang } from '../i18n';

interface Props {
  lang?: Lang;
}

const currentYear = new Date().getFullYear();
const lang = Astro.props.lang || getLangFromPath(Astro.url.pathname);

const currentPath = Astro.url.pathname;
const isStories = /^\/(?:zh\/|en\/)?stories(?:\/|$)/.test(currentPath);
const isGuides = /^\/(?:zh\/|en\/)?guides(?:\/|$)/.test(currentPath);
const rssPath = isStories
  ? `${lang}/stories/rss.xml`
  : isGuides
    ? `${lang}/guides/rss.xml`
    : `${lang}/rss.xml`;
---

<footer style="margin-top: var(--space-3xl); padding-top: var(--space-xl);">
  <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between" style="gap: var(--space-md);">
    <p class="font-sans text-xs text-[var(--color-text-muted)]">
      Indie Story
    </p>
    <div class="flex items-center gap-4">
      <a
        href={`/${rssPath}`}
        class="font-sans text-xs text-[var(--color-text-muted)] hover:text-[var(--color-hover)] transition-colors"
        target="_blank"
        rel="noopener noreferrer"
      >
        {t(lang, 'rss')}
      </a>
      <span class="font-sans text-xs text-[var(--color-text-light)]">
        {t(lang, 'footer')} · {currentYear}
      </span>
    </div>
  </div>
</footer>