---
import { t, type Lang } from '../i18n';

interface Props {
  currentPath?: string;
  lang?: Lang;
}

const { currentPath = '/' } = Astro.props;
const lang = Astro.props.lang || 'zh';

const navItems = [
  { href: '/stories', key: 'nav.stories' },
  { href: '/guides', key: 'nav.guides' },
  { href: '/about', key: 'nav.about' },
];

const prefix = lang === 'en' ? '/en' : '';

const isActive = (href: string) => {
  const fullHref = href === '/' ? (prefix || '/') : `${prefix}${href}`;
  if (fullHref === '/') {
    return currentPath === '/';
  }
  return currentPath.startsWith(fullHref);
};
---

<header class="w-full" style="padding-bottom: var(--space-lg); margin-bottom: var(--space-2xl);">
  <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between" style="gap: var(--space-md);">
    <div>
      <p class="font-sans text-xs tracking-[0.2em] text-[var(--color-text-muted)] uppercase" style="margin-bottom: var(--space-xs);">
        {t(lang, 'subtitle')}
      </p>
      <h1 class="font-display text-4xl sm:text-5xl font-semibold tracking-tight text-[var(--color-text)] leading-none">
        <a href={prefix || '/'}>Indie Story</a>
      </h1>
    </div>
    <nav class="flex items-center gap-6 sm:gap-8">
      <ul class="flex flex-wrap gap-6 sm:gap-8">
        {navItems.map((item) => {
          const fullHref = item.href === '/' ? (prefix || '/') : `${prefix}${item.href}`;
          return (
            <li>
              <a
                href={fullHref}
                class={`font-sans text-sm tracking-wide transition-all duration-200 relative group ${
                  isActive(item.href)
                    ? 'text-[var(--color-hover)] font-medium'
                    : 'text-[var(--color-text-muted)] hover:text-[var(--color-hover)]'
                }`}
              >
                {t(lang, item.key)}
                <span 
                  class={`absolute -bottom-1 left-0 h-[1px] bg-[var(--color-hover)] transition-all duration-200 ${
                    isActive(item.href) ? 'w-full' : 'w-0 group-hover:w-full'
                  }`}
                />
              </a>
            </li>
          );
        })}
      </ul>
    </nav>
  </div>
</header>