---
import { t, getAlternateLangPath, type Lang } from '../i18n';

interface Props {
  lang: Lang;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;
const targetLang: Lang = lang === 'zh' ? 'en' : 'zh';
const targetPath = getAlternateLangPath(currentPath);
---

<a
  href={targetPath}
  class="font-sans text-xs tracking-wide text-[var(--color-text-muted)] hover:text-[var(--color-hover)] transition-colors duration-200"
>
  {t(lang, 'languageSwitch')}
</a>