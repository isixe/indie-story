---
interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;

const navItems = [
  { href: '/', label: '首页' },
  { href: '/stories', label: '故事' },
  { href: '/guides', label: '指南' },
  { href: '/about', label: '关于' },
];

const isActive = (href: string) => {
  if (href === '/') {
    return currentPath === '/';
  }
  return currentPath.startsWith(href);
};
---

<nav class="w-full border-b border-[var(--color-border)]" style="padding-bottom: var(--space-lg); margin-bottom: var(--space-2xl);">
  <ul class="flex flex-wrap gap-8">
    {navItems.map((item) => (
      <li>
        <a
          href={item.href}
          class={`font-sans text-sm tracking-wide transition-all duration-200 relative group ${
            isActive(item.href)
              ? 'text-[var(--color-text)] font-medium'
              : 'text-[var(--color-text-muted)] hover:text-[var(--color-text)]'
          }`}
        >
          {item.label}
          <span 
            class={`absolute -bottom-1 left-0 h-[1px] bg-[var(--color-text)] transition-all duration-200 ${
              isActive(item.href) ? 'w-full' : 'w-0 group-hover:w-full'
            }`}
          />
        </a>
      </li>
    ))}
  </ul>
</nav>
