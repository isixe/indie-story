---
import { formatDateTime } from '../utils/posts';
import type { Post } from '../utils/posts';

interface Props {
  post: Post;
}

const { post } = Astro.props;
const dateStr = formatDateTime(post.publishDate);
---

<article class="group" style="padding: var(--space-md) 0;">
  <a href={`/post/${post.slug}`} class="block post-item-link" style="padding: var(--space-xs) var(--space-sm); margin: 0 calc(var(--space-sm) * -1); border-radius: 4px;">
    <div class="flex flex-col" style="gap: var(--space-2xs);">
      <div class="flex items-baseline justify-between gap-4">
        <div class="flex-1 min-w-0">
          <p class="font-sans text-xs text-[var(--color-text-light)] uppercase tracking-wide truncate" style="margin-bottom: var(--space-2xs);">
            {post.blogName}
          </p>
          <h3 class="font-serif text-base text-[var(--color-text)] transition-colors duration-200 leading-snug">
            {post.title}
          </h3>
        </div>
        <time class="font-sans text-xs text-[var(--color-text-light)] whitespace-nowrap flex-shrink-0" style="padding-top: var(--space-2xs);">
          {dateStr}
        </time>
      </div>
    </div>
  </a>
</article>

<style>
  .post-item-link:hover {
    background-color: var(--color-surface-subtle);
  }
  .group:hover .font-serif {
    color: var(--color-hover);
  }
</style>
