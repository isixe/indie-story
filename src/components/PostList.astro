---
import PostItem from './PostItem.astro';
import { t, getLangFromPath, type Lang } from '../i18n';
import type { Post } from '../utils/posts';

interface Props {
  posts: Post[];
  title?: string;
  showPageInfo?: boolean;
  currentPage?: number;
  totalPages?: number;
  lang?: Lang;
}

const { 
  posts, 
  title = 'Latest Updates', 
  showPageInfo = false,
  currentPage = 1,
  totalPages = 1
} = Astro.props;
const lang = Astro.props.lang || getLangFromPath(Astro.url.pathname);
---

<section class="w-full">
  <div class="flex items-center justify-between" style="margin-bottom: var(--space-md);">
    <h2 class="font-sans text-xs tracking-[0.2em] text-[var(--color-text-muted)] uppercase">
      {title}
    </h2>
    {showPageInfo && (
      <span class="font-sans text-xs text-[var(--color-text-light)]">
        {t(lang, 'page', { current: currentPage, total: totalPages })}
      </span>
    )}
  </div>
  
  <div class="lg:grid lg:grid-cols-2 lg:gap-x-12" style="--divider-color: var(--color-border);">
    {posts.map((post) => (
      <PostItem post={post} lang={lang} />
    ))}
  </div>
</section>