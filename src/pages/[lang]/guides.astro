---
import Layout from '../../layouts/Layout.astro';
import PostListWithToggle from '../../components/PostListWithToggle';
import { getPostsByCategory } from '../../utils/posts';
import { t, type Lang } from '../../i18n';

export function getStaticPaths() {
  return [
    { params: { lang: 'zh' } },
    { params: { lang: 'en' } },
  ];
}

const { lang } = Astro.params as { lang: Lang };
const guidePosts = getPostsByCategory('guide');
---

<Layout
  lang={lang}
  title={t(lang, 'guidesTitle')}
  description={t(lang, 'guidesDescription')}
>
  <div class="mb-6">
    <p class="font-serif text-[var(--color-text-muted)] text-sm leading-relaxed">
      {t(lang, 'guidesIntro')}
    </p>
  </div>
  
  <PostListWithToggle
    client:load
    posts={guidePosts}
    title={t(lang, 'allGuides')}
    lang={lang}
  />
</Layout>