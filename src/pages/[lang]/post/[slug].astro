---
import Layout from "../../../layouts/Layout.astro";
import { getPostBySlug, getPostsByLang, getAdjacentPosts, formatDateTime, renderMarkdown, extractHeadings } from "../../../utils/posts";
import { ArrowLeft, ChevronLeft, ChevronRight, ExternalLink } from "lucide-react";
import { t, type Lang } from "../../../i18n";

export function getStaticPaths() {
	const paths: { params: { lang: string; slug: string } }[] = [];
	for (const lang of ["zh", "en"] as const) {
		const langPosts = getPostsByLang(lang);
		for (const post of langPosts) {
			paths.push({ params: { lang, slug: post.slug } });
		}
	}
	return paths;
}

const { lang, slug } = Astro.params as { lang: Lang; slug: string };
const post = getPostBySlug(slug, lang);

let dateStr = "";
let renderedContent = "";
let headings: { level: number; text: string; slug: string }[] = [];
let originUrl = "";
let originHostname = "";
let prevPost: { slug: string; title: string } | null = null;
let nextPost: { slug: string; title: string } | null = null;

if (!post) {
	Astro.response.status = 404;
} else {
	dateStr = formatDateTime(post.publishDate, lang === "en" ? "en-US" : "zh-CN");
	renderedContent = post.content ? await renderMarkdown(post.content) : "";
	headings = post.content ? extractHeadings(post.content) : [];
	originUrl = post.origin || post.sourceUrl || "";
	originHostname = originUrl
		? (() => {
				try {
					return new URL(originUrl).hostname.replace(/^www\./, "");
				} catch {
					return "";
				}
			})()
		: "";
	const adjacent = getAdjacentPosts(slug, lang, post.category);
	prevPost = adjacent.prev ? { slug: adjacent.prev.slug, title: adjacent.prev.title } : null;
	nextPost = adjacent.next ? { slug: adjacent.next.slug, title: adjacent.next.title } : null;
}
---

{
	post ? (
		<Layout
			lang={lang}
			title={`${post.title} - Indie Story`}
			description={post.description || post.title}
			showUpdateTime={false}>
			<a
				href={`/${lang}/`}
				class="inline-flex items-center gap-2 font-sans text-xs text-[var(--color-text-muted)] hover:text-[var(--color-hover)] transition-colors group"
				style="margin-bottom: var(--space-2xl);">
				<ArrowLeft size={14} class="group-hover:-translate-x-1 transition-transform" />
				{t(lang, "backToList")}
			</a>

			<div class="article-layout">
				<main class="article-main">
					{/* Post header */}
					<header id="article-header" style="margin-bottom: var(--space-2xl);">
						<p
							class="font-sans text-xs text-[var(--color-text-light)] uppercase tracking-wide"
							style="margin-bottom: var(--space-sm);">
							{post.blogName}
						</p>
						<h1
							class="font-display text-2xl sm:text-3xl font-semibold text-[var(--color-text)] leading-tight"
							style="margin-bottom: var(--space-lg);">
							{post.title}
						</h1>
						<div class="flex flex-wrap items-center gap-4 font-sans text-sm text-[var(--color-text-muted)]">
							{post.author && <span>{post.author}</span>}
							<time>{dateStr}</time>
							{post.category === "story" ? (
								<span
									class="px-2 py-1 text-[var(--color-text-muted)]"
									style="background-color: var(--color-surface-subtle);">
									{t(lang, "categoryStory")}
								</span>
							) : (
								<span
									class="px-2 py-1 text-[var(--color-text-muted)]"
									style="background-color: var(--color-surface-subtle);">
									{t(lang, "categoryGuide")}
								</span>
							)}
						</div>
						{post.tags && post.tags.length > 0 && (
							<div class="flex flex-wrap gap-2" style="margin-top: var(--space-md);">
								{post.tags.map((tag) => (
									<a
										href={`/${lang}/?tag=${encodeURIComponent(tag)}`}
										class="font-sans text-sm text-[var(--color-text-light)] hover:text-[var(--color-hover)] transition-colors">
										#{tag}
									</a>
								))}
							</div>
						)}
					</header>

					{originUrl && (
						<div style="margin-bottom: var(--space-2xl); padding: var(--space-sm) 0; border-top: 1px solid var(--color-border); border-bottom: 1px solid var(--color-border);">
							<span class="inline-flex items-center gap-2 font-sans text-sm text-[var(--color-text-muted)]">
								<span class="inline-flex items-center gap-1">
									<ExternalLink size={14} />
									{t(lang, "origin")}
								</span>
								<a
									href={originUrl}
									target="_blank"
									rel="noopener noreferrer"
									class="inline-flex items-center gap-1 text-[var(--color-text)] hover:text-[var(--color-hover)] break-all">
									{originHostname || originUrl}
								</a>
							</span>
						</div>
					)}

					{/* Post content */}
					<div class="article-content text-[var(--color-text)]">
						{renderedContent ? (
							<div set:html={renderedContent} />
						) : (
							<p class="text-[var(--color-text-muted)] italic">{t(lang, "contentLoading")}</p>
						)}
					</div>

					{/* Reprint notice */}
					{originUrl && (
						<div
							style="margin-top: var(--space-3xl); padding: var(--space-lg); background-color: var(--color-surface-subtle); border-left: 3px solid var(--color-border);"
							class="font-sans text-sm text-[var(--color-text-muted)] leading-relaxed">
							{t(lang, "reprintPrefix")}
							<a
								href={originUrl}
								target="_blank"
								rel="noopener noreferrer"
								class="text-[var(--color-text)] hover:text-[var(--color-hover)] underline transition-colors">
								{originHostname || originUrl}
							</a>
							{t(lang, "reprintSuffix")}
						</div>
					)}

					{/* Prev / Next navigation */}
					{(prevPost || nextPost) && (
						<nav
							class="prev-next-nav"
							style="margin-top: var(--space-3xl); padding-top: var(--space-lg); border-top: 1px solid var(--color-border); display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-lg);">
							{prevPost ? (
								<a
									href={`/${lang}/post/${prevPost.slug}`}
									class="group flex flex-col gap-1 font-sans text-sm no-underline hover:no-underline"
									style="text-align: left;">
									<span class="inline-flex items-center gap-1 text-[var(--color-text-muted)] text-xs">
										<ChevronLeft size={14} class="group-hover:-translate-x-1 transition-transform" />
										{t(lang, "prevArticle")}
									</span>
									<span class="text-[var(--color-text)] hover:text-[var(--color-hover)] transition-colors line-clamp-2">
										{prevPost.title}
									</span>
								</a>
							) : (
								<div />
							)}
							{nextPost ? (
								<a
									href={`/${lang}/post/${nextPost.slug}`}
									class="group flex flex-col gap-1 font-sans text-sm no-underline hover:no-underline"
									style="text-align: right;">
									<span class="inline-flex items-center gap-1 justify-end text-[var(--color-text-muted)] text-xs">
										{t(lang, "nextArticle")}
										<ChevronRight size={14} class="group-hover:translate-x-1 transition-transform" />
									</span>
									<span class="text-[var(--color-text)] hover:text-[var(--color-hover)] transition-colors line-clamp-2">
										{nextPost.title}
									</span>
								</a>
							) : (
								<div />
							)}
						</nav>
					)}

					{/* Post footer */}
					<footer style="margin-top: var(--space-2xl); padding-top: var(--space-2xl);">
						<a
							href={`/${lang}/`}
							class="inline-flex items-center gap-2 font-sans text-sm text-[var(--color-text-muted)] hover:text-[var(--color-hover)] transition-colors group">
							<ArrowLeft size={16} class="group-hover:-translate-x-1 transition-transform" />
							{t(lang, "backToArticleList")}
						</a>
					</footer>
				</main>

				{headings.length > 0 && (
					<aside class="article-toc" id="article-toc">
						<nav>
							<p class="toc-label">{t(lang, "onThisPage")}</p>
							<ul>
								{headings.map((h) => (
									<li class={`toc-item toc-level-${h.level}`}>
										<a
											href={`#${h.slug}`}
											class="font-sans text-sm text-[var(--color-text-muted)] hover:text-[var(--color-hover)] transition-colors duration-200">
											{h.text}
										</a>
									</li>
								))}
							</ul>
						</nav>
					</aside>
				)}
			</div>
		</Layout>

		<style is:global>
			/* Image Lightbox */
			.lightbox-overlay {
				position: fixed;
				inset: 0;
				z-index: 99999;
				background: rgba(0, 0, 0, 0.85);
				display: flex;
				align-items: center;
				justify-content: center;
				cursor: pointer;
				opacity: 0;
				transition: opacity 0.3s ease;
			}

			.lightbox-overlay.active {
				opacity: 1;
			}

			.lightbox-overlay .lightbox-image {
				max-width: 90vw;
				max-height: 85vh;
				object-fit: contain;
				cursor: default;
				border-radius: 4px;
				box-shadow: 0 8px 40px rgba(0, 0, 0, 0.3);
			}

			.lightbox-overlay .lightbox-close {
				position: absolute;
				top: 20px;
				right: 24px;
				width: 40px;
				height: 40px;
				display: flex;
				align-items: center;
				justify-content: center;
				background: rgba(255, 255, 255, 0.1);
				border: none;
				border-radius: 50%;
				color: #fff;
				font-size: 24px;
				cursor: pointer;
				transition: background 0.2s;
				z-index: 1;
			}

			.lightbox-overlay .lightbox-close:hover {
				background: rgba(255, 255, 255, 0.2);
			}

			.lightbox-overlay .lightbox-nav {
				position: absolute;
				top: 50%;
				transform: translateY(-50%);
				width: 48px;
				height: 48px;
				display: flex;
				align-items: center;
				justify-content: center;
				background: rgba(255, 255, 255, 0.1);
				border: none;
				border-radius: 50%;
				color: #fff;
				font-size: 28px;
				cursor: pointer;
				transition: background 0.2s;
				z-index: 1;
			}

			.lightbox-overlay .lightbox-nav:hover {
				background: rgba(255, 255, 255, 0.25);
			}

			.lightbox-overlay .lightbox-prev {
				left: 24px;
			}

			.lightbox-overlay .lightbox-next {
				right: 24px;
			}

			.lightbox-overlay .lightbox-counter {
				position: absolute;
				bottom: 24px;
				left: 50%;
				transform: translateX(-50%);
				color: rgba(255, 255, 255, 0.7);
				font-family: "Inter", sans-serif;
				font-size: 14px;
				background: rgba(0, 0, 0, 0.4);
				padding: 6px 14px;
				border-radius: 20px;
				z-index: 1;
			}

			.article-content img {
				cursor: zoom-in;
			}

			@media (max-width: 640px) {
				.lightbox-overlay .lightbox-nav {
					width: 36px;
					height: 36px;
					font-size: 20px;
				}

				.lightbox-overlay .lightbox-prev {
					left: 12px;
				}

				.lightbox-overlay .lightbox-next {
					right: 12px;
				}

				.lightbox-overlay .lightbox-close {
					top: 12px;
					right: 12px;
					width: 36px;
					height: 36px;
					font-size: 20px;
				}
			}

			@media (prefers-reduced-motion: reduce) {
				.lightbox-overlay {
					transition: none;
				}
			}
		</style>

	) : (
		<Layout lang={lang} title="404 - Indie Story" showUpdateTime={false}>
			<div class="text-center" style="padding: var(--space-4xl) 0;">
				<h1
					class="font-display text-4xl font-semibold text-[var(--color-text)]"
					style="margin-bottom: var(--space-md);">
					404
				</h1>
				<p class="font-sans text-sm text-[var(--color-text-muted)]">
					{lang === "en" ? "Page not found" : "页面未找到"}
				</p>
			</div>
		</Layout>
	)
}

<script>
	const tocLinks = document.querySelectorAll("#article-toc a");
	const headingEls = Array.from(document.querySelectorAll(".article-content h2, .article-content h3")).filter(
		(h) => h.id,
	);

	function updateActiveHeading() {
		const scrollPos = window.scrollY + 100;
		let activeId = headingEls[0]?.id || "";

		for (const h of headingEls) {
			if (h.offsetTop <= scrollPos) {
				activeId = h.id;
			} else {
				break;
			}
		}

		tocLinks.forEach((link) => {
			link.classList.toggle("toc-active", link.getAttribute("href") === `#${activeId}`);
		});
	}

	if (headingEls.length > 0 && tocLinks.length > 0) {
		let ticking = false;
		document.addEventListener("scroll", () => {
			if (!ticking) {
				window.requestAnimationFrame(() => {
					updateActiveHeading();
					ticking = false;
				});
				ticking = true;
			}
		});
		updateActiveHeading();
	}

	// === Image Lightbox ===
	(function () {
		const images = Array.from(document.querySelectorAll(".article-content img"));
		if (images.length === 0) return;

		let currentIndex = 0;
		let overlay = null;

		function openLightbox(index) {
			currentIndex = index;

			overlay = document.createElement("div");
			overlay.className = "lightbox-overlay";
			overlay.setAttribute("role", "dialog");
			overlay.setAttribute("aria-label", "Image preview");

			// Close button
			const closeBtn = document.createElement("button");
			closeBtn.className = "lightbox-close";
			closeBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>';
			closeBtn.setAttribute("aria-label", "Close");
			closeBtn.addEventListener("click", function (e) {
				e.stopPropagation();
				closeLightbox();
			});
			overlay.appendChild(closeBtn);

			// Image element
			const img = document.createElement("img");
			img.className = "lightbox-image";
			img.alt = "";
			overlay.appendChild(img);

			// Navigation (only if more than one image)
			if (images.length > 1) {
				const prevBtn = document.createElement("button");
				prevBtn.className = "lightbox-nav lightbox-prev";
				prevBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>';
				prevBtn.setAttribute("aria-label", "Previous image");
				prevBtn.addEventListener("click", function (e) {
					e.stopPropagation();
					navigate(-1);
				});
				overlay.appendChild(prevBtn);

				const nextBtn = document.createElement("button");
				nextBtn.className = "lightbox-nav lightbox-next";
				nextBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>';
				nextBtn.setAttribute("aria-label", "Next image");
				nextBtn.addEventListener("click", function (e) {
					e.stopPropagation();
					navigate(1);
				});
				overlay.appendChild(nextBtn);

				const counter = document.createElement("div");
				counter.className = "lightbox-counter";
				overlay.appendChild(counter);
			}

			// Close on overlay click (not image click)
			overlay.addEventListener("click", closeLightbox);

			document.body.appendChild(overlay);
			document.body.style.overflow = "hidden";

			// Trigger fade-in animation
			requestAnimationFrame(function () {
				overlay.classList.add("active");
			});

			updateImage();
		}

		function updateImage() {
			if (!overlay) return;
			const img = overlay.querySelector(".lightbox-image");
			img.src = images[currentIndex].src;
			img.alt = images[currentIndex].alt || "";

			const counter = overlay.querySelector(".lightbox-counter");
			if (counter) {
				counter.textContent = (currentIndex + 1) + " / " + images.length;
			}
		}

		function navigate(direction) {
			currentIndex = (currentIndex + direction + images.length) % images.length;
			updateImage();
		}

		function closeLightbox() {
			if (!overlay) return;
			overlay.classList.remove("active");
			overlay.addEventListener(
				"transitionend",
				function () {
					overlay.remove();
					overlay = null;
				},
				{ once: true },
			);
			document.body.style.overflow = "";
			// Fallback if transitionend doesn't fire
			setTimeout(function () {
				if (overlay) {
					overlay.remove();
					overlay = null;
					document.body.style.overflow = "";
				}
			}, 350);
		}

		// Add click handlers to images (skip images inside links)
		images.forEach(function (img, index) {
			if (img.closest("a")) return;
			img.addEventListener("click", function (e) {
				e.preventDefault();
				openLightbox(index);
			});
		});

		// Keyboard navigation
		document.addEventListener("keydown", function (e) {
			if (!overlay) return;
			switch (e.key) {
				case "Escape":
					e.preventDefault();
					closeLightbox();
					break;
				case "ArrowLeft":
					e.preventDefault();
					navigate(-1);
					break;
				case "ArrowRight":
					e.preventDefault();
					navigate(1);
					break;
			}
		});
	})();

	// === Code Copy Button ===
	(function () {
		const blocks = document.querySelectorAll(".article-content .shiki");
		if (blocks.length === 0) return;

		blocks.forEach(function (pre) {
			const code = pre.querySelector("code");
			if (!code) return;

			const btn = document.createElement("button");
			btn.className = "code-copy-btn";
			btn.textContent = "Copy";

			btn.addEventListener("click", async function (e) {
				e.stopPropagation();
				try {
					await navigator.clipboard.writeText(code.textContent || "");
					btn.textContent = "Copied!";
					btn.classList.add("copied");
					setTimeout(function () {
						btn.textContent = "Copy";
						btn.classList.remove("copied");
					}, 2000);
				} catch {
					btn.textContent = "Failed";
					setTimeout(function () {
						btn.textContent = "Copy";
					}, 2000);
				}
			});

			pre.appendChild(btn);
		});
	})();
</script>
