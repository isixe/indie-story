---
import Layout from '../../../layouts/Layout.astro';
import { getPostBySlug, getPostsByLang, formatDateTime } from '../../../utils/posts';
import { ArrowLeft } from 'lucide-react';
import { t, type Lang } from '../../../i18n';

export function getStaticPaths() {
  const paths: { params: { lang: string; slug: string } }[] = [];
  for (const lang of ['zh', 'en'] as const) {
    const langPosts = getPostsByLang(lang);
    for (const post of langPosts) {
      paths.push({ params: { lang, slug: post.slug } });
    }
  }
  return paths;
}

const { lang, slug } = Astro.params as { lang: Lang; slug: string };
const post = getPostBySlug(slug, lang);

if (!post) {
  return Astro.redirect('/404');
}

const dateStr = formatDateTime(post.publishDate, lang === 'en' ? 'en-US' : 'zh-CN');
---

<Layout 
  lang={lang}
  title={`${post.title} - Indie Story`}
  description={post.description || post.title}
  showUpdateTime={false}
>
  <article class="mx-auto" style="max-width: 672px;">
    {/* Back button */}
    <a 
      href={`/${lang}/`}
      class="inline-flex items-center gap-2 font-sans text-xs text-[var(--color-text-muted)] hover:text-[var(--color-hover)] transition-colors group"
      style="margin-bottom: var(--space-2xl);"
    >
      <ArrowLeft size={14} class="group-hover:-translate-x-1 transition-transform" />
      {t(lang, 'backToList')}
    </a>
    
    {/* Post header */}
    <header style="margin-bottom: var(--space-2xl); padding-bottom: var(--space-2xl);">
      <p class="font-sans text-xs text-[var(--color-text-light)] uppercase tracking-wide" style="margin-bottom: var(--space-sm);">
        {post.blogName}
      </p>
      <h1 class="font-display text-2xl sm:text-3xl font-semibold text-[var(--color-text)] leading-tight" style="margin-bottom: var(--space-lg);">
        {post.title}
      </h1>
      <div class="flex flex-wrap items-center gap-4 font-sans text-xs text-[var(--color-text-muted)]">
        <time>{dateStr}</time>
        {post.category === 'story' ? (
          <span class="px-2 py-1 text-[var(--color-text-muted)]" style="background-color: var(--color-surface-subtle);">{t(lang, 'categoryStory')}</span>
        ) : (
          <span class="px-2 py-1 text-[var(--color-text-muted)]" style="background-color: var(--color-surface-subtle);">{t(lang, 'categoryGuide')}</span>
        )}
      </div>
      {post.tags && post.tags.length > 0 && (
        <div class="flex flex-wrap gap-2" style="margin-top: var(--space-md);">
          {post.tags.map((tag) => (
            <span class="font-sans text-xs text-[var(--color-text-light)]">
              #{tag}
            </span>
          ))}
        </div>
      )}
    </header>
    
    {/* Post content */}
    <div class="article-content text-[var(--color-text)]">
      {post.content ? (
        <div set:html={post.content.replace(/\n/g, '<br/>').replace(/## (.*)/g, '<h2>$1</h2>').replace(/### (.*)/g, '<h3>$1</h3>').replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>').replace(/- (.*)/g, '<li>$1</li>')} />
      ) : (
        <p class="text-[var(--color-text-muted)] italic">{t(lang, 'contentLoading')}</p>
      )}
    </div>
    
    {/* Post footer */}
    <footer style="margin-top: var(--space-3xl); padding-top: var(--space-2xl);">
      <a 
        href={`/${lang}/`}
        class="inline-flex items-center gap-2 font-sans text-sm text-[var(--color-text-muted)] hover:text-[var(--color-hover)] transition-colors group"
      >
        <ArrowLeft size={16} class="group-hover:-translate-x-1 transition-transform" />
        {t(lang, 'backToArticleList')}
      </a>
    </footer>
  </article>
</Layout>