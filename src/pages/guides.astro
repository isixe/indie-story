---
import Layout from '../layouts/Layout.astro';
import PostListWithToggle from '../components/PostListWithToggle';
import { getPostsByCategory } from '../utils/posts';

const guidePosts = getPostsByCategory('guide');
---

<Layout 
  title="实用指南 - Indie Story"
  description="独立开发者必备的实用指南：SEO、上架、注册公司、收款方案等"
>
  <div class="mb-6">
    <p class="font-serif text-[var(--color-text-muted)] text-sm leading-relaxed">
      这里汇集了独立开发者最需要的实用指南。从 App Store 上架流程到公司注册，
      从 SEO 优化到收款方案选择，帮助你解决独立开发路上的各种实际问题。
    </p>
  </div>
  
  <PostListWithToggle 
    client:load
    posts={guidePosts} 
    title="All Guides"
  />
</Layout>
