---
import Layout from '../layouts/Layout.astro';
import PostListWithToggle from '../components/PostListWithToggle';
import Pagination from '../components/Pagination.astro';
import { getPostsByPage, getPostsByCategory } from '../utils/posts';

// 获取故事分类的文章作为主页展示
const storyPosts = getPostsByCategory('story');
const pageSize = 20;
const totalPages = Math.ceil(storyPosts.length / pageSize);
const currentPage = 1;
const posts = storyPosts.slice(0, pageSize);
---

<Layout 
  title="Indie Story - 独立开发者故事"
  description="收集和分享独立开发者的真实故事，记录独立开发的点点滴滴"
>
  <PostListWithToggle 
    client:load
    posts={posts} 
    title="Latest Stories"
    showPageInfo={totalPages > 1}
    currentPage={currentPage}
    totalPages={totalPages}
  />
  
  <Pagination 
    currentPage={currentPage} 
    totalPages={totalPages}
    baseUrl="/"
  />
</Layout>
