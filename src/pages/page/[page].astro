---
import { getPostsByCategory } from '../../utils/posts';

export function getStaticPaths() {
  const pageSize = 20;
  const storyPosts = getPostsByCategory('story');
  const totalPages = Math.ceil(storyPosts.length / pageSize);

  const paths = [];
  for (let page = 2; page <= totalPages; page++) {
    paths.push({ params: { page: page.toString() } });
  }
  return paths;
}

const { page } = Astro.params;
return Astro.redirect(`/zh/page/${page}`, 301);
