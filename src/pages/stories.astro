---
import Layout from '../layouts/Layout.astro';
import PostListWithToggle from '../components/PostListWithToggle';
import { getPostsByCategory } from '../utils/posts';
import { t } from '../i18n';

const storyPosts = getPostsByCategory('story', 'zh');
---

<Layout
  lang="zh"
  title={t('zh', 'storiesTitle')}
  description={t('zh', 'storiesDescription')}
>
  <div class="mb-6">
    <p class="font-serif text-[var(--color-text-muted)] text-sm leading-relaxed">
      {t('zh', 'storiesIntro')}
    </p>
  </div>
  
  <PostListWithToggle
    client:load
    posts={storyPosts}
    title={t('zh', 'allStories')}
    lang="zh"
  />
</Layout>
