---
import Layout from '../layouts/Layout.astro';
import PostListWithToggle from '../components/PostListWithToggle';
import { getPostsByCategory } from '../utils/posts';

const storyPosts = getPostsByCategory('story');
---

<Layout 
  title="独立开发者故事 - Indie Story"
  description="真实的独立开发者经历分享，从0到1的创业故事"
>
  <div class="mb-6">
    <p class="font-serif text-[var(--color-text-muted)] text-sm leading-relaxed">
      这里收录了独立开发者们的真实故事。从辞去工作全职独立开发，到副业变主业的转型经历，
      从失败中总结的教训到成功后的经验分享，每一个故事都是一段独特的人生旅程。
    </p>
  </div>
  
  <PostListWithToggle 
    client:load
    posts={storyPosts} 
    title="All Stories"
  />
</Layout>
